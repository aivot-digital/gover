  "scripts": {
    "git-info": "node scripts/get-git-info.js",
    "start:customer": "REACT_APP_BUILD_TARGET=customer PORT=3000 react-scripts start",
    "start:customer:win": "set REACT_APP_BUILD_TARGET=customer&& set PORT=3000&& set ESLINT_NO_DEV_ERRORS=true&& react-scripts start",
    "start:staff": "REACT_APP_BUILD_TARGET=staff PORT=3001 react-scripts start",
    "start:staff:win": "set REACT_APP_BUILD_TARGET=staff&& set PORT=3001&& set ESLINT_NO_DEV_ERRORS=true&& react-scripts start",
    "build:customer": "npm run git-info && BUILD_PATH=../src/main/resources/static REACT_APP_BUILD_TARGET=customer react-scripts build",
    "build:staff": "npm run git-info && BUILD_PATH=../src/main/resources/static/admin REACT_APP_BUILD_TARGET=staff PUBLIC_URL=/admin react-scripts build",
    "build": "npm run build:customer && npm run build:staff",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
